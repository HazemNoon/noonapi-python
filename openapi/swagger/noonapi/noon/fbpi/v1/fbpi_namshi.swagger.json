              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "fbpi_order_nr",
            "description": "The order number used in the request.",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "FBPI Order"
        ],
        "x-max-requests": 1500,
        "x-time-window": 60,
        "x-burst": 1500,
        "x-burst-time-window": 60
      }
    },
    "/v1/fbpi-orders/list": {
      "post": {
        "summary": "ListFbpiOrders",
        "description": "Retrieves a paginated list of FBPI orders for a specific warehouse with optional filtering by order creation date range.\n\nUse the created_after and created_before filters to  limit results to orders created within a specific UTC time window.If no date filters are provided,all available orders for the specified warehouse will be returned.Results are returned in pages of up to 50 orders.\n\nTo retrieve additional pages,include the next_token query parameter returned in the previous response. When paginating, you must reuse the same filters applied in the initial request. The next_token controls pagination only and does not modify the result set.",
        "operationId": "FbpiService_ListFbpiOrders",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListFbpiOrdersResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "filters",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1ListFbpiOrdersFilters"
            }
          },
          {
            "name": "next_token",
            "description": "used for pagination. When requesting pages after the \nfirst, provide the token returned by your previous request, and do not change the filters applied\nin the first page when sending the token.",
            "in": "query",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "FBPI Order"
        ],
        "x-max-requests": 1500,
        "x-time-window": 60,
        "x-burst": 1500,
        "x-burst-time-window": 60
      }
    },
    "/v1/fbpi-order/{fbpi_order_nr}/customer-details/get": {
      "get": {
        "summary": "GetFbpiOrderCustomerData",
        "description": "Provides customer details for a given FBPI order, including their name, city, and administrative division.",
        "operationId": "FbpiService_GetFbpiOrderCustomerData",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetFbpiOrderCustomerDataResponse"
