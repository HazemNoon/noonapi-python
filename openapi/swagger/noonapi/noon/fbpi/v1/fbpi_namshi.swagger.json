            "required": true,
            "schema": {
              "$ref": "#/definitions/v1AddShipmentCourierAwbsRequest"
            }
          }
        ],
        "tags": [
          "Shipment"
        ],
        "x-max-requests": 1500,
        "x-time-window": 60,
        "x-burst": 1500,
        "x-burst-time-window": 60
      }
    },
    "/v1/shipment/cancel": {
      "post": {
