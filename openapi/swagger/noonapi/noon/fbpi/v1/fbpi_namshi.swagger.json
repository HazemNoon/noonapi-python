    "/v1/fbpi-order/{fbpi_order_nr}/get": {
      "get": {
        "summary": "GetFbpiOrder",
        "description": "A webhook will be sent to your system containing theorder details whenever an order is created from the marketplace (Noon or Namshi).\nYou can then use the fbpi_order_nr from the webhookto call this endpoint and retrieve full order details.",
        "operationId": "FbpiService_GetFbpiOrder",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetFbpiOrderResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
