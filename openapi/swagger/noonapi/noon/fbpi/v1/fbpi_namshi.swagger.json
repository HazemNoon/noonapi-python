        "x-max-requests": 1500,
        "x-time-window": 60,
        "x-burst": 1500,
        "x-burst-time-window": 60
      }
    },
    "/v1/fbpi-order/update": {
      "post": {
        "summary": "UpdateOrder",
        "description": "If the warehouse stock does not match the received order,this API allows you to mark one or more items as unavailable before shipment creation.\nThe unavailable items will be canceled on Noon’s side,and the rest will proceed to fulfillment.",
        "operationId": "FbpiService_UpdateOrder",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "type": "object",
              "properties": {}
            }
          },
          "default": {
            "description": "An unexpected error response.",
