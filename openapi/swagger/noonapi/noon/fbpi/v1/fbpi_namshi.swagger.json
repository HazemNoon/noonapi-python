    "/v1/shipment/noon-logistics-awbs/get": {
      "post": {
        "summary": "GetNoonLogisticsAWBs",
        "description": "Generates Noon AWB numbers to be used when creating shipments.\nYou can generate a single AWB per shipment or request up to 1000 AWBs in bulk and store them for future use.",
